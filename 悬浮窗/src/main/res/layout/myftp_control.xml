<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="fill_parent"
	android:layout_height="fill_parent"
	android:orientation="vertical">

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="horizontal"
		android:gravity="center">

		<com.yzrilyzr.ui.myButton
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:text="启动服务器"
			android:layout_weight="1.0"
			android:layout_margin="5dp"
			android:id="@+id/myftpcontrolButton1"/>

		<com.yzrilyzr.ui.myEditText
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:hint="端口"
			android:layout_margin="5dp"
			android:inputType="number"
			android:text="3721"
			android:id="@+id/myftpcontrolEditText1"/>

		<com.yzrilyzr.ui.myLoadingView
			android:layout_height="40dp"
			android:layout_width="40dp"
			android:layout_margin="5dp"
			android:id="@+id/myftpcontrolProgressBar1"
			android:visibility="gone"/>

	</LinearLayout>

	<com.yzrilyzr.ui.myLinearLayout
		android:layout_height="3px"
		android:layout_width="match_parent"
		android:orientation="horizontal"/>

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="horizontal"
		android:layout_margin="5dp"
		android:gravity="center">

		<com.yzrilyzr.ui.myButton
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:text="用户管理"
			android:id="@+id/myftpcontrolButton2"/>

		<LinearLayout
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:orientation="horizontal"
			android:layout_weight="1.0"/>

		<com.yzrilyzr.ui.myTextView
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:text="允许匿名登录"
			android:gravity="center"
			android:layout_marginLeft="6dp"/>

		<com.yzrilyzr.ui.mySwitch
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:id="@+id/myftpcontrolSwitch1"/>

	</LinearLayout>

	<com.yzrilyzr.ui.myEditText
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:layout_marginLeft="10dp"
		android:layout_marginRight="10dp"
		android:hint="匿名文件主目录"
		android:id="@+id/myftpcontrolEditText2"/>

</LinearLayout>

