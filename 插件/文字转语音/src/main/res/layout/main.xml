<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">

	<com.yzrilyzr.ui.myEditText
		android:layout_height="match_parent"
		android:layout_width="match_parent"
		android:layout_weight="1.0"
		android:id="@+id/mainEditText1"/>

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="horizontal">

		<com.yzrilyzr.ui.myButton
			android:layout_height="wrap_content"
			android:text="粘贴播放"
			android:layout_width="match_parent"
			android:id="@+id/paste"
			android:layout_weight="1.0"/>

		<com.yzrilyzr.ui.myButton
			android:layout_height="wrap_content"
			android:text="播放"
			android:layout_width="match_parent"
			android:id="@+id/speak"
			android:layout_weight="1.0"/>

		<com.yzrilyzr.ui.myButton
			android:layout_height="wrap_content"
			android:text="停止"
			android:layout_width="match_parent"
			android:id="@+id/stop"
			android:layout_weight="1.0"/>

		<com.yzrilyzr.ui.myLoadingView
			android:layout_height="50dp"
			android:layout_width="50dp"
			android:id="@+id/mainmyLoadingView1"/>

	</LinearLayout>

	<com.yzrilyzr.ui.mySpinner
		android:layout_height="wrap_content"
		android:layout_width="wrap_content"
		items="女声,男声,特别男声,情感男声,情感童声"
		android:id="@+id/mainmySpinner1"/>

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="horizontal"
		android:gravity="left|center">

		<TextView
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:text="语速"/>

		<com.yzrilyzr.ui.mySeekBar
			android:layout_height="wrap_content"
			android:max="9"
			android:progress="5"
			android:layout_width="match_parent"
			android:id="@+id/mainmySeekBar3"/>

	</LinearLayout>

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="horizontal"
		android:gravity="left|center">

		<TextView
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:text="音调"/>

		<com.yzrilyzr.ui.mySeekBar
			android:layout_height="wrap_content"
			android:max="9"
			android:progress="5"
			android:layout_width="match_parent"
			android:id="@+id/mainmySeekBar4"/>

	</LinearLayout>

</LinearLayout>

